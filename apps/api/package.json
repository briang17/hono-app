{
	"name": "@apps/api",
	"main": "./index.ts",
	"types": "./index.ts",
	"scripts": {
		"dev": "bun --port 3001 src/index.ts",
		"cq": "biome check --write",
		"cq:deep": "biome lint --write --only=nursery/noImportCycles --only=security/noSecrets",
		"build": "bun build src/index.ts --outdir dist/ --target bun"
	},
	"dependencies": {
		"@hono/zod-validator": "^0.7.6",
		"@packages/auth": "workspace:*",
		"@packages/database": "workspace:*",
		"@packages/env": "workspace:*",
		"@packages/secrets": "workspace:*",
		"drizzle-orm": "^0.45.1",
		"hono": "^4.12.8",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.11",
		"@types/bun": "latest"
	}
}